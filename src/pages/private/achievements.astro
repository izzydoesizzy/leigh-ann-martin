---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

// Skill: write-achievements (2-column Achievement | Description table).
// Every metric is confirmed or reliably estimated from Leigh-Ann's intake transcripts.
// No em dashes anywhere on this page.
// Chronological order: DGB, R&T, PwC, Third Bridge, Immunovant, Ascend.

const roles = [
  {
    id: "petrotrin",
    company: "Petrotrin",
    title: "Admin Assistant, Office of the VP of Oil & Refining",
    dates: "Age 18 through September 2006 US migration",
    industry: "Trinidad state-owned vertically integrated oil company",
    achievements: [
      {
        label: "Career Origin",
        description:
          "Started corporate-track career at age 18 at Petrotrin, Trinidad's state-owned vertically integrated oil company and the country's largest employer pre-2018 dissolution, supporting the Office of the VP of Oil & Refining (who reported directly to the GM) through the executive assistant's team with responsibility for filing, interoffice mail, and exposure to refinery operations documentation across all of refining and marketing.",
      },
    ],
  },
  {
    id: "bearingpoint",
    company: "BearingPoint",
    title: "Administrative support, Finance / Treasury (NYC)",
    dates: "November 2007 through Chapter 11 wind-down",
    industry: "Management consulting (Chapter 11 bankruptcy)",
    achievements: [
      {
        label: "First US Corporate Role",
        description:
          "Supported 4 finance leaders (VP, Treasurer, VP of Finance, plus one additional) at BearingPoint starting November 2007, first US corporate role after migrating from Trinidad in 2006, covering accounts payable, accounts receivable, and wire-transfer workflows from the firm's offices in the American Express towers on Vesey Street.",
