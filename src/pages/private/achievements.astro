const totalAchievements = roles.reduce((sum, r) => sum + r.achievements.length, 0);
---

<Layout title="Achievements, Leigh-Ann Martin (Private)">
  <Header />
  <main>
    <!-- Hero -->
    <section class="pt-28 pb-14 md:pt-32 md:pb-16 bg-cream">
      <div class="max-w-4xl mx-auto px-6" data-reveal>
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-secondary mb-4">
          Private, for Leigh-Ann and Izzy only
        </p>
        <h1 class="font-serif text-4xl md:text-5xl text-primary leading-tight mb-6">
          Achievements, resume-ready, quantified.
        </h1>
        <p class="text-text-muted text-lg leading-relaxed max-w-2xl">
          Every quantified achievement from your intake transcripts, formatted as the 2-column table the <code class="font-mono text-sm bg-warm px-1.5 py-0.5 rounded">write-achievements</code> skill produces. Copy these straight into your resume, LinkedIn, consulting proposal, or cover letters. {totalAchievements} achievements across {roles.length} roles.
        </p>
      </div>
    </section>

    <!-- Jump nav -->
    <section class="py-8 bg-white border-b border-primary/[0.06]">
      <div class="max-w-4xl mx-auto px-6" data-reveal>
        <div class="flex flex-wrap gap-2 justify-start items-center">
          <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-text-muted mr-3">Jump to</p>
          {roles.map((r) => (
            <a
              href={`#${r.id}`}
              class="inline-block bg-cream border border-primary/10 text-primary px-3 py-1.5 rounded-full text-xs font-medium hover:bg-primary hover:text-white transition-all"
            >
              {r.company}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Role-by-role tables -->
    <section id="tables" class="py-14 md:py-16 bg-warm">
      <div class="max-w-4xl mx-auto px-6">
        {roles.map((role, idx) => (
          <article id={role.id} class={`${idx > 0 ? "mt-14" : ""}`} data-reveal>
            <header class="mb-5">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-1">
                <h2 class="font-serif text-2xl md:text-3xl text-primary leading-tight">{role.company}</h2>
                <p class="text-[11px] font-semibold uppercase tracking-wider text-secondary">{role.dates}</p>
              </div>
              <p class="text-primary/80 text-[15px] font-medium">{role.title}</p>
              <p class="text-text-muted text-sm mt-1">{role.industry}</p>
            </header>

            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-primary/[0.08]">
              <table class="w-full border-collapse">
                <thead>
                  <tr class="bg-cream/60 border-b border-primary/10">
                    <th class="text-left text-[11px] font-semibold tracking-[0.15em] uppercase text-primary py-3 px-5 w-[28%] align-top">Achievement</th>
                    <th class="text-left text-[11px] font-semibold tracking-[0.15em] uppercase text-primary py-3 px-5 align-top">Description</th>
                  </tr>
                </thead>
                <tbody>
                  {role.achievements.map((ach, i) => (
                    <tr class={i > 0 ? "border-t border-primary/[0.06]" : ""}>
                      <td class="py-4 px-5 align-top">
                        <p class="font-serif text-[15px] text-primary font-semibold leading-snug">{ach.label}</p>
                      </td>
                      <td class="py-4 px-5 align-top">
                        <p class="text-text text-[14px] leading-relaxed">{ach.description}</p>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Source discipline -->
    <section class="py-16 bg-primary text-white">
      <div class="max-w-3xl mx-auto px-6 text-center" data-reveal>
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-accent mb-4">Source discipline</p>
        <h2 class="font-serif text-2xl md:text-3xl leading-tight mb-5">
          Every number traces back to your own words.
        </h2>
        <p class="text-white/75 leading-relaxed">
          Confirmed numbers are stated verbatim in your intake transcripts. Numbers marked "approximately" are estimates you made yourself in conversation with Izzy (30% DGB process reduction, 20% R&T accuracy gain, 30% Immunovant decision velocity, employee #17 to 19 at Immunovant). The 98% Ascend stakeholder satisfaction rate on your consulting proposal is your own estimate based on chairman-of-the-board and ELT responsiveness, not a formal survey. Nothing on this page was invented.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>
