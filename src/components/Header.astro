---
const base = import.meta.env.BASE_URL;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-lg shadow-sm">
  <nav class="max-w-4xl mx-auto px-6 flex items-center justify-between h-16">
    <a href={base} class="font-serif text-xl text-primary font-semibold">ClearCareer</a>
    <div class="flex items-center gap-6">
      <a href={`${base}services`} class="text-text-muted text-sm font-medium hover:text-primary transition-colors hidden sm:inline">Services</a>
      <a
        href="#next-steps"
        class="bg-secondary text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-secondary/90 transition-all cursor-pointer"
      >
        Let's Go
      </a>
    </div>
  </nav>
</header>
