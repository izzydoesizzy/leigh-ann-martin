---
const base = import.meta.env.BASE_URL;
---

<section id="top" class="relative min-h-[85vh] flex items-center bg-navy overflow-hidden">
  <!-- Mesh gradient blurs -->
  <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-blue/20 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-[-10%] left-[-10%] w-[400px] h-[400px] bg-blue/10 rounded-full blur-[100px]"></div>

  <div class="relative max-w-[1080px] mx-auto px-6 pt-28 pb-20 md:pt-36 md:pb-28 grid md:grid-cols-12 gap-10 md:gap-12 items-center">
    <!-- Photo -->
    <div class="md:col-span-4 flex justify-center md:justify-start">
      <div class="relative">
        <div class="absolute -inset-2 rounded-2xl border border-white/10"></div>
        <div class="w-48 h-48 md:w-56 md:h-56 rounded-2xl overflow-hidden ring-1 ring-white/10 shadow-2xl">
          <img
            src={`${base}leigh-ann.jpg`}
            alt="Leigh-Ann Martin"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>

    <!-- Text -->
    <div class="md:col-span-8">
      <div class="inline-flex items-center gap-2 bg-blue/10 backdrop-blur-sm border border-blue/20 rounded-full px-4 py-1.5 mb-6">
        <span class="w-2 h-2 rounded-full bg-blue animate-pulse"></span>
        <span class="text-blue-bg text-xs font-semibold tracking-widest uppercase">A plan for Leigh-Ann Martin</span>
      </div>

      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl text-white leading-[1.15] mb-6">
        10+ years of executive-level work.<br />
        Now it becomes
        <span class="text-gradient">your business.</span>
      </h1>

      <p class="text-white/50 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
        In 4 weeks, you'll have your own website, your own service packages, your own client pipeline, and a clear plan to go after the people who need exactly what you do.
      </p>

      <a
        href="#situation"
        class="inline-flex items-center gap-2 bg-blue text-white px-6 py-3 rounded-lg text-sm font-semibold hover:bg-blue-dark transition-all cursor-pointer"
      >
        See the full plan
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 bg-white/[0.03] backdrop-blur-sm border-t border-white/[0.06]">
    <div class="max-w-[1080px] mx-auto px-6 py-5 flex flex-wrap justify-center gap-x-10 gap-y-2 text-[13px] text-white/40 font-medium tracking-wide">
      <span>From Izzy Piyale-Sheard</span>
      <span class="hidden sm:inline text-white/15">|</span>
      <span>ClearCareer</span>
      <span class="hidden sm:inline text-white/15">|</span>
      <span>April 14, 2026</span>
    </div>
  </div>
</section>
